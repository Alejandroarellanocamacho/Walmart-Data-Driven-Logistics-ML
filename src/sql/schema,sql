-- Borra la tabla si ya existe para empezar limpios 
DROP TABLE IF EXISTS transactions;

-- Crear el schena,sql con los tipos de datos correctos 
CREATE TABLE transactions (
    transaction_id INT PRIMARY KEY,
    customer_id INT,
    product_id INT,
    product_name VARCHAR(150),
    category VARCHAR(50),
    quantity_sold INT,
    unit_price NUMERIC(10, 2),
    transaction_date TIMESTAMP,
    store_id INT,
    store_location VARCHAR(100),
    inventory_level INT,
    reorder_point INT,
    reorder_quantity INT,
    supplier_id INT,
    supplier_lead_time INT,
    customer_age INT,
    customer_gender VARCHAR(20),
    customer_income NUMERIC(15, 2),
    customer_loyalty_level VARCHAR(20),
    payment_method VARCHAR(50),
    promotion_applied BOOLEAN,
    promotion_type VARCHAR(50),
    weather_conditions VARCHAR(50),
    holiday_indicator BOOLEAN,
    weekday VARCHAR(20),
    stockout_indicator BOOLEAN,
    forecasted_demand INT,
    actual_demand INT
);
